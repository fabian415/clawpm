# ClawPM Backend - Container Manager Config

# OpenClaw Docker image
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.22

# Port range for per-user OpenClaw containers (gateway + bridge, 2 ports per user)
OPENCLAW_PORT_RANGE_START=18800
OPENCLAW_PORT_RANGE_END=19799

# Base directory for per-user workspaces
# Linux production: /home/advantech/.openclaw/users
# Windows local test: leave empty to use %USERPROFILE%\.openclaw\users
CLAWPM_WORKSPACE_BASE=

# Path to source skills directory (copied to each user workspace)
OPENCLAW_SKILLS_SOURCE_PATH=../../references/skills

# Local JSON file for port allocation tracking (no DB needed for CLI test)
CLAWPM_PORT_DB_PATH=./data/ports.json

# Local JSON file for container config tracking (no DB needed for CLI test)
CLAWPM_CONTAINER_DB_PATH=./data/containers.json

# Docker socket path (Linux: /var/run/docker.sock, Windows Docker Desktop: npipe:////./pipe/docker_engine)
# Leave empty to use dockerode defaults
DOCKER_SOCKET_PATH=

# API Server
API_PORT=3000
JWT_SECRET=change-this-to-a-random-secret-in-production
