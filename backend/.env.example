# ClawPM Backend - Container Manager Config
# 此檔案由 docker-compose env_file: 注入容器，本機開發直接用 dotenv 讀取

# OpenClaw Docker image
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.22
OPENCLAW_IMAGE=clawpm-openclaw:2026.4.22-py

# Port range for per-user OpenClaw containers (gateway + bridge, 2 ports per user)
OPENCLAW_PORT_RANGE_START=18800
OPENCLAW_PORT_RANGE_END=19799

# Base directory for per-user workspaces
# 本機開發：實際路徑；Docker 容器內：對應 volume 的掛載路徑
CLAWPM_WORKSPACE_BASE=/Users/fabian/.openclaw/users

# Path to source skills directory (copied to each user workspace)
OPENCLAW_SKILLS_SOURCE_PATH=./skills

# PostgreSQL connection (docker-compose 自動注入 DATABASE_URL；本機開發請填寫)
DATABASE_URL=postgres://clawpm:yourpassword@localhost:5432/clawpm

# Docker socket path (Linux: /var/run/docker.sock, Windows Docker Desktop: npipe:////./pipe/docker_engine)
DOCKER_SOCKET_PATH=

# Debug logging — uncomment to enable [chat] [sendAndStream] [azure-proxy] verbose logs
# DEBUG_LOGS=1

# WhisperX transcription server
LOCAL_SERVER_IP=172.22.12.27
LOCAL_SERVER_PORT=8787
# LOCAL_API_KEY=   # Uncomment if the WhisperX server requires an API key

# Extraction
MAX_TERMS=30

# ess-kms 知識庫 GraphQL（補充文件連結萃取 → 抓頁面內容用）
# token 只放後端、不會傳進容器；容器內腳本只負責從文件萃取 URL
ESS_KMS_GRAPHQL_ENDPOINT=https://ess-kms.edgecenter.io/graphql
ESS_KMS_GRAPHQL_TOKEN=
ESS_KMS_LOCALE=en
# ess-kms 憑證是公司內部 CA（ACLCA）簽發，Node 不像瀏覽器/curl 會讀 Windows 系統信任的憑證，
# 需額外指定信任鏈才能連線，否則 fetch 會以 SELF_SIGNED_CERT_IN_CHAIN 失敗。
# 注意：Node 只在 process 啟動當下讀這個變數，本機用 npm run server/dev 靠 package.json 的
# cross-env 帶入才有效；docker-compose 是靠 env_file 在容器啟動前注入，這裡設定同樣適用。
NODE_EXTRA_CA_CERTS=./certs/advantech-ca-chain.pem

# Email (SendGrid) — for meeting notes delivery（/api/workflow/send-meeting-email）
# 到 SendGrid 後台 Settings > API Keys 建立一組至少有 Mail Send 權限的 API Key
# 寄件者 SENDGRID_FROM_EMAIL 需先在 SendGrid 完成 Single Sender Verification 或 Domain Authentication，
# 否則寄送會被拒絕（HTTP 403）
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=memosynth@edgecenter.io
EMAIL_FROM_NAME=MemoSynth 會議助理

# API Server
API_PORT=3002
JWT_SECRET=change-this-to-a-random-secret-in-production
# 允許外部 IP 的前端存取（逗號分隔），例如：http://192.168.1.100:5173,http://10.0.0.5:5173
# CORS_ORIGIN=http://192.168.1.100:5173

# FTP Server
# Docker 內用 21（container 內部 port）；本機開發直接連 host 用 2121
FTP_PORT=21
FTP_USER=advantech
FTP_PASS=P@ssw0rd

SEARXNG_BASE_URL=http://searxng-core:8788

# Blog Rewriter sidecar（技術分享文章 → 部落格文章）
# docker-compose 已在 compose 內部網路把這個值設成 http://clawpm-blog-rewriter:8010，
# 本機開發（backend 不在 docker 內跑）時改成 http://localhost:8010（對應 BLOG_REWRITER_PORT）
BLOG_REWRITER_URL=http://localhost:8010

# Azure DevOps Hugo 部落格 repo（部落格草稿「發布/取消發布」用）
# 每次發布/取消發布都是全新 clone 到暫存目錄操作完即刪除，不會在 backend 容器內常駐這個 repo。
AZURE_DEVOPS_REPO_URL=https://dev.azure.com/AdvLLM/AI_Image_Generator/_git/hugo-static-app
AZURE_DEVOPS_BRANCH=main
AZURE_DEVOPS_PAT=
