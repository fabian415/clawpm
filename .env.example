# ── 共用路徑（backend + ftp 共享） ────────────────────────────────────────
# Linux production: /home/advantech/.openclaw/users
# Windows local:   C:/Users/<you>/.openclaw/users
CLAWPM_WORKSPACE_BASE=

# ── FTP 伺服器 ─────────────────────────────────────────────────────────────
# 主機對外 IP（PASV 模式回傳給 FTP client 使用）
FTP_SERVER_IP=

# FTP 資料目錄（掛載到容器內 /home/vsftpd/<FTP_USER>）
# Linux production: /home/advantech/.openclaw/workspace/ftp_data
# Windows local:   C:/Users/<you>/.openclaw/workspace/ftp_data
FTP_DATA_PATH=

# FTP 帳號密碼
FTP_USER=advantech
FTP_PASS=changeme
