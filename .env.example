# ── OpenClaw Container Image ────────────────────────────────────────────────
# 預設使用官方 image；若已執行 docker/build.ps1 或 build.sh 自建含 Python 套件的版本，
# 請改為下方自建 tag
OPENCLAW_IMAGE=clawpm-openclaw:2026.4.22-py

# ── 共用路徑（backend + ftp 共享） ────────────────────────────────────────
# Linux production: /home/advantech/.openclaw/users
# Windows local:   C:/Users/<you>/.openclaw/users
CLAWPM_WORKSPACE_BASE=/Users/fabian/.openclaw

# ── FTP 伺服器 ─────────────────────────────────────────────────────────────
# 主機對外 IP（PASV 模式回傳給 FTP client 使用）
FTP_SERVER_IP=192.168.0.12

# FTP 帳號密碼
FTP_USER=advantech
FTP_PASS=P@ssw0rd
