# ── OpenClaw Container Image ────────────────────────────────────────────────
# 預設使用官方 image；若已執行 docker/build.ps1 或 build.sh 自建含 Python 套件的版本，
# 請改為下方自建 tag
OPENCLAW_IMAGE=clawpm-openclaw:2026.4.22-py

# ── 共用路徑（backend + ftp 共享） ────────────────────────────────────────
# Linux production: /home/advantech/.openclaw/users
# Windows local:   C:/Users/<you>/.openclaw/users
CLAWPM_WORKSPACE_BASE=/Users/fabian/.openclaw/users

# ── FTP 伺服器 ─────────────────────────────────────────────────────────────
# 主機對外 IP（PASV 模式回傳給 FTP client 使用）
FTP_SERVER_IP=192.168.0.12

# FTP 帳號密碼
FTP_USER=advantech
FTP_PASS=P@ssw0rd

# ── ClawPM Backend ─────────────────────────────────────────────────────────
# 對外 port（容器內固定 3000）
API_PORT=3000

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# 資料庫名稱與帳號（可保持預設）
POSTGRES_DB=clawpm
POSTGRES_USER=clawpm
# 必填：請更改為強密碼
POSTGRES_PASSWORD=change-this-to-a-strong-password

# ── WhisperX Transcribe API ────────────────────────────────────────────────
# 對外 port（容器內固定 8000）
TRANSCRIBE_PORT=8787

# ── Unoserver（LibreOffice 轉檔 sidecar，給 PPTX 整頁截圖用） ────────────────
# 對外 port（容器內固定 2003）；per-user OpenClaw 容器透過 host.docker.internal:此 port 連線
UNOSERVER_PORT=2003
