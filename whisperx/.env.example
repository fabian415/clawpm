# WhisperX Transcribe API - Container Config
# 此檔案由 docker-compose env_file: 注入容器

# HuggingFace token（pyannote 說話人分離需要，申請後填入）
HF_TOKEN=hf_I*******************NAZYD

# 對外監聽 port（容器內固定 8000，透過 docker-compose ports 映射）
PORT=8000

# 上傳檔案大小上限 (MB)
MAX_FILE_MB=500

# 轉錄任務 timeout (秒)
JOB_TIMEOUT_SECONDS=10800

# 已完成任務保留時間 (小時)
JOB_TTL_HOURS=48

# 說話人辨識相似度門檻（0~1，越高越嚴格）
SPEAKER_SIMILARITY_THRESHOLD=0.75

# 標點符號詞彙表上限
MAX_TERMS=30
