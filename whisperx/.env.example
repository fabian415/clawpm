# WhisperX Transcribe API - Container Config
# 此檔案由 docker-compose env_file: 注入容器

# HuggingFace token（pyannote 說話人分離需要，申請後填入）
HF_TOKEN=hf_I*******************NAZYD

# 對外監聽 port（容器內固定 8000，透過 docker-compose ports 映射）
PORT=8000

# 上傳檔案大小上限 (MB)
MAX_FILE_MB=500

# 轉錄任務 timeout (秒)
JOB_TIMEOUT_SECONDS=10800

# 已完成任務保留時間 (小時)
JOB_TTL_HOURS=48

# 說話人辨識相似度門檻（0~1，越高越嚴格）
SPEAKER_SIMILARITY_THRESHOLD=0.75

# 標點符號詞彙表上限
MAX_TERMS=30

# ── 轉錄引擎（伺服器端決定，不由 API 呼叫者選擇）──────────────────────────
# whisperx：本地 WhisperX（含語者分離，預設）
# azure：Azure MAI-Transcribe（無語者分離）
# azure_diarize：Azure MAI-Transcribe + 強制對齊重建時間戳 + 語者分離（實驗性）
TRANSCRIBE_ENGINE=whisperx

# ── Azure MAI-Transcribe（TRANSCRIBE_ENGINE=azure 或 azure_diarize 時使用）──
# Speech / Foundry 資源端點與金鑰。未設定則無法使用 azure / azure_diarize 引擎。
AZURE_SPEECH_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_SPEECH_KEY=your-speech-resource-key
